{
  "name": "starmode-site",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "prettier --check . && astro build && tsc",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "og": "npx @resvg/resvg-js-cli --fit-width 2400 public/starmode-og.svg public/starmode-og.png",
    "icons": "bun run scripts/generate-icons.ts",
    "clean:soft": "rm -rf node_modules tsconfig.tsbuildinfo .astro dist && bun install",
    "clean:hard": "rm -rf node_modules tsconfig.tsbuildinfo .astro dist bun.lock && bun install"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "astro-icon": "^1.1.5",
    "onedollarstats": "^0.0.19",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@iconify-json/ph": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "wrangler": "^4.84.1"
  }
}
